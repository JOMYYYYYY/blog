---
import BaseLayout from "./BaseLayout.astro";
import Giscus from "../components/Giscus.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  prev?: CollectionEntry<"blog"> | null;
  next?: CollectionEntry<"blog"> | null;
  readingTime?: number;
}
const { post, prev, next, readingTime } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const d = pubDate;
const dateStr = `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, "0")}/${String(d.getDate()).padStart(2, "0")}`;
---

<BaseLayout title={title} description={description}>
  <article>
    <header style="margin-bottom:2rem;">
      <h1 style="font-size:2rem;margin-bottom:0.5rem;">{title}</h1>
      <div style="color:var(--text-secondary);font-size:0.9rem;display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {readingTime && <span>· {readingTime} <span data-i18n="reading_time">分钟</span></span>}
        {tags.length > 0 && (
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
            {tags.map(tag => (
              <span style="background:var(--bg-secondary);padding:2px 8px;border-radius:4px;font-size:0.8rem;">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>
      <div data-pagefind-meta="tags:{tags.join(',')}"></div>
      <div class="prose">
        <slot />
      </div>
  </article>

  {(prev || next) && (
    <nav style="display:flex;justify-content:space-between;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);">
      <div>
        {prev && (
          <a href={`/blog/${prev.id}/`} style="text-decoration:none;color:var(--text);">
            <span style="display:block;font-size:0.8rem;color:var(--text-secondary);" data-i18n="post.prev">← 上一篇</span>
            <span style="font-weight:500;">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div style="text-align:right;">
        {next && (
          <a href={`/blog/${next.id}/`} style="text-decoration:none;color:var(--text);">
            <span style="display:block;font-size:0.8rem;color:var(--text-secondary);" data-i18n="post.next">下一篇 →</span>
            <span style="font-weight:500;">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <hr style="margin:3rem 0;border:none;border-top:1px solid var(--border);" />
  <Giscus />
</BaseLayout>
