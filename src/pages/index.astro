---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Yaxing Tan">
  <section style="padding:4rem 0 2rem;">
    <h1 style="font-size:3rem;font-weight:700;margin-bottom:0.5rem;">Yaxing Tan</h1>
    <p style="font-size:1.2rem;color:var(--text-secondary);margin-bottom:1.5rem;font-style:italic;">Less is more</p>
    <div style="display:flex;gap:1rem;align-items:center;">
      <a href="https://github.com/JOMYYYYYY" target="_blank" rel="noopener noreferrer" style="color:var(--accent);text-decoration:none;font-size:0.9rem;">GitHub →</a>
    </div>
  </section>
  <section style="padding:2rem 0;">
    <a href="/blog" style="display:inline-block;padding:0.75rem 2rem;background:var(--accent);color:#fff;text-decoration:none;border-radius:6px;font-weight:500;">浏览文章</a>
  </section>
</BaseLayout>
